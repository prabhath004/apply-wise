{
  "manifest_version": 3,
  "name": "ApplyIntel",
  "description": "Analyze job fit locally, research public company signals, and generate focused outreach.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "sidePanel", "scripting", "tabs"],
  "host_permissions": ["http://localhost:8000/*", "https://*.linkedin.com/*"],
  "background": {
    "service_worker": "assets/serviceWorker.js",
    "type": "module"
  },
  "action": {
    "default_title": "ApplyIntel",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidebar.html"
  }
}
